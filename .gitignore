# ============================================================
# Multi-Tag Agent – .gitignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
wheels/
MANIFEST

# ── Virtual environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ── Environment / secrets ────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ── pytest / coverage ────────────────────────────────────────
.pytest_cache/
.cache/
reports/
htmlcov/
*.cover
.coverage
.coverage.*
coverage.xml

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── IDEs & Editors ───────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── OS generated ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── mypy / type checkers ─────────────────────────────────────
.mypy_cache/
.dmypy.json
.pyright/

# ── Locust / load test artifacts ─────────────────────────────
locust_*.csv
locust_*.log
